# JackTrack Environment Configuration

# Required: 17Track API key (get one at https://user.17track.net/)
SEVENTEEN_TRACK_API_KEY=your_17track_api_key_here

# Required: Resend API key (get one at https://resend.com/)
RESEND_API_KEY=your_resend_api_key_here

# Optional: Port for the HTTP server (default: 3000)
PORT=3000

# Optional: SQLite database path (default: ./data/jacktrack.db)
DATABASE_URL=./data/jacktrack.db

# Optional: Polling interval in milliseconds (default: 900000 = 15 min)
POLL_INTERVAL_MS=900000

# Optional: 17Track API base URL (default: https://api.17track.net/v2.4)
SEVENTEEN_TRACK_API_URL=https://api.17track.net/v2.4

# Optional: Sender email address (default: tracking@jacktrack.app)
FROM_EMAIL=tracking@jacktrack.app
